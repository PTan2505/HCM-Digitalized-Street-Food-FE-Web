{
  "ignoreCommand": "if [ \"$VERCEL_GIT_COMMIT_REF\" != \"main\" ]; then exit 0; else exit 1; fi",
  "rewrites": [
    {
      "source": "/hubs/:path*",
      "destination": "http://11.11.11.94:5276/hubs/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "http://11.11.11.94:5276/api/:path*"
    },
    {
      "source": "/openmap/:path*",
      "destination": "https://mapapis.openmap.vn/:path*"
    },
    { "source": "/((?!\\.well-known).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/.well-known/assetlinks.json",
      "headers": [
        { "key": "Content-Type", "value": "application/json" },
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    }
  ]
}
