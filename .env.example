# Địa chỉ URL của API server
VITE_API_URL="http://your-api-url.com/api"

# Địa chỉ URL của SignalR server dùng để nhận thông báo realtime
VITE_SIGNALR_URL="http://your-signalr-url.com/hubs/notifications"

# Google Client ID dùng cho tính năng đăng nhập bằng Google trên Web
VITE_GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"

# Google iOS Client ID dùng cho tính năng đăng nhập bằng Google trên iOS
VITE_GOOGLE_IOS_CLIENT_ID="your-google-ios-client-id.apps.googleusercontent.com"

# Facebook App ID dùng cho tính năng đăng nhập bằng Facebook
VITE_FACEBOOK_APP_ID="your-facebook-app-id"

# API Key cho dịch vụ bản đồ OpenMap
VITE_OPENMAP_API_KEY="your-openmap-api-key"

# API Key cho dịch vụ Google Gemini AI
VITE_GEMINI_API_KEY="your-gemini-api-key"
